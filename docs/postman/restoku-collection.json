{
  "info": {
    "name": "Restoku API v1",
    "description": "Complete API collection for Restoku POS & Restaurant Management System",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000/api/v1"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "restaurant_id",
      "value": ""
    },
    {
      "key": "menu_id",
      "value": ""
    },
    {
      "key": "order_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health",
            "description": "Check if API is running"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has status field', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('status');",
                  "    pm.expect(json.status).to.eql('ok');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@restoku.id\",\n  \"password\": \"password\"\n}"
            },
            "description": "Login and get access token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Token is returned', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('token');",
                  "    pm.environment.set('access_token', json.data.token);",
                  "    pm.environment.set('restaurant_id', json.data.user.restaurant_id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "description": "Get authenticated user profile"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('User has required fields', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data).to.have.property('email');",
                  "    pm.expect(json.data).to.have.property('role');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "description": "Invalidate current token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.environment.unset('access_token');"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "description": "Get new access token using refresh token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('New token is returned', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('token');",
                  "    pm.environment.set('access_token', json.data.token);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Menus",
      "item": [
        {
          "name": "List Menus",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/menus?page=1&per_page=20",
              "host": ["{{base_url}}"],
              "path": ["menus"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" }
              ]
            },
            "description": "Get list of menus with pagination"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has pagination', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json).to.have.property('meta');",
                  "    pm.expect(json.meta).to.have.property('total');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Menu",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/menus",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nasi Goreng Spesial\",\n  \"price\": 25000,\n  \"category_id\": \"{{category_id}}\",\n  \"description\": \"Nasi goreng dengan telur dan ayam\",\n  \"is_available\": true\n}"
            },
            "description": "Create a new menu item"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Menu has id', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.environment.set('menu_id', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Menu",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/menus/{{menu_id}}",
            "description": "Get menu detail by ID"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Menu has correct fields', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('name');",
                  "    pm.expect(json.data).to.have.property('price');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Menu",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/menus/{{menu_id}}",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Nasi Goreng Spesial Updated\",\n  \"price\": 30000\n}"
            },
            "description": "Update menu item"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Menu",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/menus/{{menu_id}}",
            "description": "Delete menu item"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', function () {",
                  "    pm.response.to.have.status(204);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/orders?page=1&per_page=20&status=pending",
              "host": ["{{base_url}}"],
              "path": ["orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "per_page", "value": "20" },
                { "key": "status", "value": "pending" }
              ]
            },
            "description": "Get list of orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/orders",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_number\": 5,\n  \"items\": [\n    {\n      \"menu_id\": \"{{menu_id}}\",\n      \"quantity\": 2,\n      \"notes\": \"Pedas\"\n    }\n  ]\n}"
            },
            "description": "Create a new order"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Order has id and total', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('id');",
                  "    pm.expect(json.data).to.have.property('total');",
                  "    pm.environment.set('order_id', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/orders/{{order_id}}",
            "description": "Get order detail"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "url": "{{base_url}}/orders/{{order_id}}/status",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"confirmed\"\n}"
            },
            "description": "Update order status"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Tables",
      "item": [
        {
          "name": "List Tables",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/restaurants/{{restaurant_id}}/tables",
            "description": "Get list of tables"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Table",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/restaurants/{{restaurant_id}}/tables",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Meja 1\",\n  \"number\": 1\n}"
            },
            "description": "Create a new table"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Generate QR Code",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/restaurants/{{restaurant_id}}/tables/qr",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"table_ids\": [\"table-uuid-1\", \"table-uuid-2\"]\n}"
            },
            "description": "Generate QR codes for tables"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Public API",
      "item": [
        {
          "name": "Get Public Menu",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/public/menu/{{restaurant_id}}",
            "auth": null,
            "description": "Get menu for public view (no auth required)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has menus array', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('menus');",
                  "    pm.expect(json.data.menus).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Public Order",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/public/orders",
            "auth": null,
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"restaurant_id\": \"{{restaurant_id}}\",\n  \"table_number\": 5,\n  \"items\": [\n    {\n      \"menu_id\": \"{{menu_id}}\",\n      \"quantity\": 2,\n      \"variant\": \"Pedas\",\n      \"notes\": \"Tanpa bawang\"\n    }\n  ],\n  \"notes\": \"Mohon cepat\"\n}"
            },
            "description": "Create order from public QR menu (no auth)"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Order has order_id and estimated_time', function () {",
                  "    var json = pm.response.json();",
                  "    pm.expect(json.data).to.have.property('order_id');",
                  "    pm.expect(json.data).to.have.property('estimated_time');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Public Order Status",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/public/orders/{{order_id}}",
            "auth": null,
            "description": "Get order status for public tracking"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Sales Report",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/reports/sales?period=daily&date=2026-07-23",
              "host": ["{{base_url}}"],
              "path": ["reports", "sales"],
              "query": [
                { "key": "period", "value": "daily" },
                { "key": "date", "value": "2026-07-23" }
              ]
            },
            "description": "Get sales report"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Menu Analytics",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/reports/menu-analytics?period=7d",
            "description": "Get menu performance analytics"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
