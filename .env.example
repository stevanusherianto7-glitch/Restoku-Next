# ===========================================
# Restoku - Frontend Environment Variables
# ===========================================

# API Configuration
VITE_API_URL=http://localhost:8000/api/v1
VITE_API_TIMEOUT=30000

# Mock mode (MSW runtime) — set true untuk demo/e2e tanpa backend Laravel
VITE_USE_MOCKS=false

# Cloudinary (media delivery) — cloud name is public, safe in the browser.
# Defaults to Restoku's cloud "dwdaydzsh" if unset.
VITE_CLOUDINARY_CLOUD_NAME=dwdaydzsh

# App Configuration
VITE_APP_NAME=Restoku
VITE_APP_URL=http://localhost:3000

# WebSocket (for real-time updates)
VITE_WS_URL=ws://localhost:8000

# Feature Flags
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_ANALYTICS=false
